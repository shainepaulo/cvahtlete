# ============================================================================
# ATHLETE CV — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs.
# .env.local n'est JAMAIS commité (déjà couvert par .gitignore).
# ============================================================================

# --- Supabase --------------------------------------------------------------
# supabase.com → ton projet → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# service_role : SERVEUR UNIQUEMENT. Ne jamais l'exposer au client / au repo.
# Utilisée par le script de seed du compte propriétaire et les webhooks.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Compte propriétaire (godpower) ----------------------------------------
# Semé une seule fois par le script de seed (lecture service_role).
# Choisis un mot de passe FORT. Toi seul le connais ; il ne transite nulle part.
ADMIN_EMAIL=toi@exemple.com
ADMIN_PASSWORD=

# --- Stripe (paiements) ----------------------------------------------------
# dashboard.stripe.com → Developers → API keys / Webhooks
# Aucune donnée carte ne touche notre serveur : Stripe héberge le paiement.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
